    <versionNumber>1.0.0</versionNumber>
    <platforms>
        <platform name="Android-ARM">
            <applicationDeployment>
                <nativeLibrary>foreground-ext.jar</nativeLibrary>
                <initializer>com.aqw.foreground.ForegroundExtension</initializer>
            </applicationDeployment>
        </platform>
        <platform name="Android-ARM64">
            <applicationDeployment>
                <nativeLibrary>foreground-ext.jar</nativeLibrary>
